# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "openai" or "huggingface"
LLM_PROVIDER=openai

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0

# ─── Store ───────────────────────────────────────────────────────────────────
# Options: "file", "chroma", or "sqlite"
STORE_BACKEND=file
NOTE_FILE=data/notepad.txt
MAX_NOTE_FILE_SIZE_MB=10
CHROMA_COLLECTION=notepad
CHROMA_PERSIST_DIR=data/chroma_db
SQLITE_DB_URL=sqlite:///data/notepad.db

# ─── Retrieval ───────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=3

# ─── Web Search ──────────────────────────────────────────────────────────────
WEB_SEARCH_MAX_RESULTS=5

# ─── Server ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# API key for authenticating requests (leave empty to disable auth in development)
API_KEY=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Responsible AI Audit (optional — Azure Blob for production) ─────────────
# Set audit_backend to "azure_blob" in src/config/config.json to enable
# AUDIT_AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
